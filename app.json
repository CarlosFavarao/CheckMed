{
  "expo": {
    "name": "check-med",
    "slug": "check-med",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "checkmed",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "predictiveBackGestureEnabled": false,
      "package": "com.carlosfavarao.checkmed"
    },
    "web": {
      "output": "static"
    },
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "fe284474-00ee-4823-a418-37141ea57511"
      }
    }
  }
}